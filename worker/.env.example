# Worker — Environment Variables
# Copy this to .env and fill in your values.

# ─── Database (Supabase — DIRECT connection only) ────────────────────────────
# Worker uses DIRECT connection for atomic claim transactions (FOR UPDATE SKIP LOCKED).
# Also set DATABASE_URL to the same direct URL (worker doesn't use the pooled URL).
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres?connection_limit=5"
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres?connection_limit=5"

# ─── Backend API ─────────────────────────────────────────────────────────────
API_BASE_URL="http://localhost:3001/api/v1"

# ─── Worker Config ───────────────────────────────────────────────────────────
WORKER_CONCURRENCY=5
POLL_INTERVAL_MS=2000
HEARTBEAT_INTERVAL_MS=10000
SHUTDOWN_TIMEOUT_MS=30000
