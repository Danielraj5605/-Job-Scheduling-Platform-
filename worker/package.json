{
  "name": "job-scheduler-worker",
  "version": "1.0.0",
  "description": "Distributed Job Scheduler — Worker Service",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "db:generate": "prisma generate --schema ../backend/prisma/schema.prisma"
  },
  "prisma": {
    "schema": "../backend/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "prisma": "^5.14.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0"
  }
}
